{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:YOUR_SERVER.database.windows.net,1433;Initial Catalog=CivicPulseDb;Persist Security Info=False;User ID=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "AzureAISearch": {
    "Endpoint": "https://YOUR_SEARCH.search.windows.net",
    "AdminApiKey": "YOUR_KEY",
    "IndexName": "events-index"
  },
  "AzureAIVision": {
    "Endpoint": "https://YOUR_VISION.cognitiveservices.azure.com",
    "ApiKey": "YOUR_KEY"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "ChatModel": "gpt-4o-mini"
  },
  "Jwt": {
    "Secret": "YOUR_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG_HERE",
    "Issuer": "CivicPulse",
    "Audience": "CivicPulse",
    "ExpiryMinutes": 1440
  },
  "FrontendUrl": "http://localhost:3000"
}
